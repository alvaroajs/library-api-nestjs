model Book {
  id            Int      @id @default(autoincrement())
  title         String
  author        String
  publishedYear Int
  status        Status   @default(AVAILABLE)
  loans         Loan[]
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
  loans Loan[]
}

enum Status {
  AVAILABLE
  BORROWED
}